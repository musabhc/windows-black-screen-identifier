<Window x:Class="BlackScreenIdentifier.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Black Screen Identifier"
        Width="1520"
        Height="980"
        MinWidth="1280"
        MinHeight="820"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.4*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Black Screen Identifier" Style="{StaticResource HeroTitleStyle}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Cold-boot siyah ekranını pasif loglarla, boot seanslarıyla ve rehberli sonraki açılış capture akışıyla teşhis eder."
                               Style="{StaticResource HeroSubtitleStyle}" />
                    <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                        <Border Style="{StaticResource PillStyle}">
                            <TextBlock Text="{Binding StatusText}" Style="{StaticResource PillTextStyle}" />
                        </Border>
                        <Border Margin="10,0,0,0" Style="{StaticResource PillStyle}">
                            <TextBlock Text="{Binding UpdateStatusText}" Style="{StaticResource PillTextStyle}" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock HorizontalAlignment="Right" Text="{Binding VersionText}" Style="{StaticResource MetaLabelStyle}" />
                    <TextBlock Margin="0,6,0,20"
                               HorizontalAlignment="Right"
                               Text="{Binding MachineDescriptor}"
                               Style="{StaticResource MetaValueStyle}" />
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Command="{Binding QuickScanCommand}" Content="Hızlı Tarama" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Command="{Binding DeepScanCommand}" Content="Derin Analiz" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Command="{Binding CheckUpdatesCommand}" Content="Sürüm Kontrolü" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Command="{Binding ExportBundleCommand}" Content="Tanı Paketi" Style="{StaticResource SecondaryButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="1" Margin="0,20,0,20" ItemsSource="{Binding SummaryCards}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="340" Margin="0,0,18,18" Padding="20" Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Width="14" Height="14" HorizontalAlignment="Right" CornerRadius="7" Background="{Binding AccentBrush}" />
                            <TextBlock Text="{Binding Label}" Style="{StaticResource CardLabelStyle}" />
                            <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="{Binding Value}" Style="{StaticResource CardValueStyle}" />
                            <TextBlock Grid.Row="2" Margin="0,8,0,0" Text="{Binding Subtitle}" Style="{StaticResource CardBodyStyle}" TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.32*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Margin="0,0,18,18" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Bulgular ve Güven Skoru" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding Findings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,14" Padding="18" CornerRadius="18" Background="{StaticResource InnerCardBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="8" CornerRadius="4" Background="{Binding AccentBrush}" />
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                <WrapPanel>
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                                    <Border Margin="10,0,0,0" Style="{StaticResource TagStyle}">
                                                        <TextBlock Text="{Binding SeverityLabel}" Style="{StaticResource TagTextStyle}" />
                                                    </Border>
                                                    <Border Margin="8,0,0,0" Style="{StaticResource TagStyle}">
                                                        <TextBlock Text="{Binding ConfidenceLabel}" Style="{StaticResource TagTextStyle}" />
                                                    </Border>
                                                </WrapPanel>
                                                <TextBlock Margin="0,10,0,0" Text="{Binding Summary}" Style="{StaticResource CardBodyStyle}" TextWrapping="Wrap" />
                                                <TextBlock Margin="0,10,0,0" Text="{Binding WhyItMatters}" Style="{StaticResource MetaLabelStyle}" TextWrapping="Wrap" />
                                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding EvidenceLines}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="0,0,0,4" Text="{Binding}" Style="{StaticResource ListLineStyle}" TextWrapping="Wrap" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Margin="0,0,18,18" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Düzeltmeler ve Geri Alma" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding Actions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,14" Padding="18" CornerRadius="18" Background="{StaticResource InnerCardBrush}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <WrapPanel>
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                                <Border Margin="10,0,0,0" Style="{StaticResource TagStyle}">
                                                    <TextBlock Text="{Binding RiskLabel}" Style="{StaticResource TagTextStyle}" />
                                                </Border>
                                                <Border Margin="8,0,0,0" Style="{StaticResource TagStyle}">
                                                    <TextBlock Text="{Binding RequirementLabel}" Style="{StaticResource TagTextStyle}" />
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="{Binding Preview}" Style="{StaticResource CardBodyStyle}" TextWrapping="Wrap" />
                                            <WrapPanel Grid.Row="2" Margin="0,16,0,0">
                                                <Button Command="{Binding DataContext.ApplyActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Uygula"
                                                        Style="{StaticResource PrimaryButtonStyle}" />
                                                <Button Command="{Binding DataContext.RollbackActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Geri Al"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Margin="0,0,0,18" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Boot Denemeleri" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding BootAttempts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,14" Padding="18" CornerRadius="18" Background="{StaticResource InnerCardBrush}">
                                        <StackPanel>
                                            <WrapPanel>
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource ItemTitleStyle}" />
                                                <Border Margin="10,0,0,0" Style="{StaticResource TagStyle}">
                                                    <TextBlock Text="{Binding StartedAt}" Style="{StaticResource TagTextStyle}" />
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Margin="0,8,0,0" Text="{Binding Summary}" Style="{StaticResource CardBodyStyle}" TextWrapping="Wrap" />
                                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Highlights}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="0,0,0,4" Text="{Binding}" Style="{StaticResource ListLineStyle}" TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Oturum Geçmişi" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding Sessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="16" CornerRadius="16" Background="{StaticResource InnerCardBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Subtitle}" Style="{StaticResource CardBodyStyle}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
