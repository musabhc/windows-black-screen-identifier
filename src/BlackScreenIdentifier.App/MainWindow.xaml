<Window x:Class="BlackScreenIdentifier.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Black Screen Identifier"
        Width="1380"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource TopBarBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Black Screen Identifier" Style="{StaticResource WindowTitleStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Cold-boot siyah ekranı için masaüstü tanı çalışma alanı. Son incident, boot sinyalleri ve düzeltmeler tek görünümde tutulur."
                               Style="{StaticResource HeroSubtitleStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock HorizontalAlignment="Right" Text="{Binding VersionText}" Style="{StaticResource CaptionStyle}" />
                    <TextBlock Margin="0,4,0,10"
                               HorizontalAlignment="Right"
                               Text="{Binding MachineDescriptor}"
                               Style="{StaticResource MetaValueStyle}" />
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Command="{Binding QuickScanCommand}" Content="Hızlı Tarama" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Command="{Binding DeepScanCommand}" Content="Derin Analiz" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Command="{Binding CheckUpdatesCommand}" Content="Sürüm Kontrolü" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Command="{Binding ExportBundleCommand}" Content="Tanı Paketi" Style="{StaticResource SecondaryButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SidebarBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource MutedPanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Son Incident" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Margin="0,10,0,0" Text="{Binding SelectedIncident.Title}" Style="{StaticResource ItemTitleStyle}" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding SelectedIncident.Subtitle}" Style="{StaticResource CaptionStyle}" />
                                <TextBlock Margin="0,10,0,0" Text="{Binding SelectedIncident.PrimarySummary}" Style="{StaticResource BodyTextStyle}" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Border Style="{StaticResource PillStyle}">
                                        <TextBlock Text="{Binding SelectedIncident.ConfidenceLabel}" Style="{StaticResource PillTextStyle}" />
                                    </Border>
                                    <Border Margin="8,0,0,0" Style="{StaticResource PillStyle}">
                                        <TextBlock Text="{Binding SelectedIncident.CollectionLabel}" Style="{StaticResource PillTextStyle}" />
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,16,0,8" Text="Boot Denemeleri" Style="{StaticResource SectionTitleStyle}" />
                        <ListBox ItemsSource="{Binding BootAttempts}"
                                 SelectedItem="{Binding SelectedBootAttempt}"
                                 MaxHeight="220"
                                 Style="{StaticResource DesktopListBoxStyle}"
                                 ItemContainerStyle="{StaticResource DesktopListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{Binding AccentBrush}" CornerRadius="3" />
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource ItemTitleStyle}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding StartedAt}" Style="{StaticResource CaptionStyle}" />
                                                <TextBlock Margin="0,6,0,0" Text="{Binding Summary}" Style="{StaticResource BodyTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Margin="0,16,0,8" Text="Önerilen Eylemler" Style="{StaticResource SectionTitleStyle}" />
                        <ItemsControl ItemsSource="{Binding Actions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10" Style="{StaticResource PanelBorderStyle}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                            <TextBlock Margin="0,4,0,0" Text="{Binding Summary}" Style="{StaticResource BodyTextStyle}" />
                                            <TextBlock Margin="0,4,0,0" Text="{Binding RequirementLabel}" Style="{StaticResource CaptionStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,16,0,8" Text="Oturumlar" Style="{StaticResource SectionTitleStyle}" />
                        <ListBox ItemsSource="{Binding IncidentHistory}"
                                 SelectedItem="{Binding SelectedIncidentItem}"
                                 Style="{StaticResource DesktopListBoxStyle}"
                                 ItemContainerStyle="{StaticResource DesktopListBoxItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="5" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{Binding AccentBrush}" CornerRadius="3" />
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding PrimaryFinding}" Style="{StaticResource BodyTextStyle}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding Subtitle}" Style="{StaticResource CaptionStyle}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding StatusLabel}" Style="{StaticResource CaptionStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource SoftBorderBrush}" />

            <Border Grid.Column="2" Style="{StaticResource DetailBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource MutedPanelBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding SelectedIncident.PrimaryFinding}" Style="{StaticResource WindowTitleStyle}" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding SelectedIncident.Subtitle}" Style="{StaticResource CaptionStyle}" />
                                <TextBlock Margin="0,12,0,0" Text="{Binding SelectedIncident.PrimarySummary}" Style="{StaticResource BodyTextStyle}" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding SelectedIncident.WhyItMatters}" Style="{StaticResource BodyTextStyle}" />
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding SelectedIncident.Facts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,8,8" Style="{StaticResource PillStyle}">
                                                <TextBlock Text="{Binding}" Style="{StaticResource PillTextStyle}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                <Border Margin="0,0,0,8" Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Tarama Durumu" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding StatusText}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,0,8" Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Sürüm Durumu" Style="{StaticResource SectionTitleStyle}" />
                                        <WrapPanel Margin="0,6,0,0">
                                            <Border Background="{Binding UpdateAccentBrush}" CornerRadius="8" Padding="8,3">
                                                <TextBlock Foreground="White" Text="{Binding UpdateBadgeText}" Style="{StaticResource PillTextStyle}" />
                                            </Border>
                                        </WrapPanel>
                                        <TextBlock Margin="0,8,0,0" Text="{Binding UpdateStatusText}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Dışa Aktar" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding ExportStatus.StateLabel}" Style="{StaticResource MetaValueStyle}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding ExportStatus.Summary}" Style="{StaticResource BodyTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="1"
                                Margin="0,14,0,0"
                                SelectedIndex="{Binding SelectedDetailTabIndex}"
                                Style="{StaticResource TabControlStyle}">
                        <TabItem Header="Teşhis" Style="{StaticResource TabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Findings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Style="{StaticResource PanelBorderStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="{Binding AccentBrush}" CornerRadius="3" />
                                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                        <WrapPanel>
                                                            <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                                            <Border Margin="8,0,0,0" Style="{StaticResource PillStyle}">
                                                                <TextBlock Text="{Binding SeverityLabel}" Style="{StaticResource PillTextStyle}" />
                                                            </Border>
                                                            <Border Margin="8,0,0,0" Style="{StaticResource PillStyle}">
                                                                <TextBlock Text="{Binding ConfidenceLabel}" Style="{StaticResource PillTextStyle}" />
                                                            </Border>
                                                        </WrapPanel>
                                                        <TextBlock Margin="0,8,0,0" Text="{Binding Summary}" Style="{StaticResource BodyTextStyle}" />
                                                        <TextBlock Margin="0,8,0,0" Text="{Binding WhyItMatters}" Style="{StaticResource BodyTextStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Kanıtlar" Style="{StaticResource TabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding EvidenceGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Style="{StaticResource PanelBorderStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                                    <TextBlock Margin="0,4,0,0" Text="{Binding Summary}" Style="{StaticResource CaptionStyle}" />
                                                    <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Lines}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Margin="0,0,0,6" Text="{Binding}" Style="{StaticResource BodyTextStyle}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Düzeltmeler" Style="{StaticResource TabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Actions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Style="{StaticResource PanelBorderStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <WrapPanel>
                                                        <TextBlock Text="{Binding Title}" Style="{StaticResource ItemTitleStyle}" />
                                                        <Border Margin="8,0,0,0" Style="{StaticResource PillStyle}">
                                                            <TextBlock Text="{Binding RiskLabel}" Style="{StaticResource PillTextStyle}" />
                                                        </Border>
                                                        <Border Margin="8,0,0,0" Style="{StaticResource PillStyle}">
                                                            <TextBlock Text="{Binding RequirementLabel}" Style="{StaticResource PillTextStyle}" />
                                                        </Border>
                                                    </WrapPanel>
                                                    <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="{Binding Summary}" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Grid.Row="1" Margin="0,28,0,0" Text="{Binding Preview}" Style="{StaticResource CaptionStyle}" />
                                                    <WrapPanel Grid.Row="2" Margin="0,14,0,0">
                                                        <Button Command="{Binding DataContext.ApplyActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Content="Uygula"
                                                                Style="{StaticResource PrimaryButtonStyle}" />
                                                        <Button Command="{Binding DataContext.RollbackActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Content="Geri Al"
                                                                Style="{StaticResource SecondaryButtonStyle}" />
                                                    </WrapPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Capture" Style="{StaticResource TabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Border Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel>
                                        <WrapPanel>
                                            <TextBlock Text="{Binding CaptureStatus.Title}" Style="{StaticResource ItemTitleStyle}" />
                                            <Border Margin="8,0,0,0" Background="{Binding CaptureStatus.AccentBrush}" CornerRadius="8" Padding="8,3">
                                                <TextBlock Foreground="White" Text="{Binding CaptureStatus.StateLabel}" Style="{StaticResource PillTextStyle}" />
                                            </Border>
                                        </WrapPanel>
                                        <TextBlock Margin="0,10,0,0" Text="{Binding CaptureStatus.Summary}" Style="{StaticResource BodyTextStyle}" />
                                        <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding CaptureStatus.DetailLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,0,0,6" Text="{Binding}" Style="{StaticResource BodyTextStyle}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Dışa Aktar" Style="{StaticResource TabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Border Style="{StaticResource PanelBorderStyle}">
                                    <StackPanel>
                                        <WrapPanel>
                                            <TextBlock Text="{Binding ExportStatus.Title}" Style="{StaticResource ItemTitleStyle}" />
                                            <Border Margin="8,0,0,0" Style="{StaticResource PillStyle}">
                                                <TextBlock Text="{Binding ExportStatus.StateLabel}" Style="{StaticResource PillTextStyle}" />
                                            </Border>
                                        </WrapPanel>
                                        <TextBlock Margin="0,10,0,0" Text="{Binding ExportStatus.Summary}" Style="{StaticResource BodyTextStyle}" />
                                        <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ExportStatus.DetailLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Margin="0,0,0,6" Text="{Binding}" Style="{StaticResource BodyTextStyle}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Margin="0,14,0,0"
                                                Command="{Binding ExportBundleCommand}"
                                                Content="{Binding ExportStatus.ButtonLabel}"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
