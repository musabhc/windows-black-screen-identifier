             LinkBase="Linked\Actions" />
    <Compile Include="..\..\src\BlackScreenIdentifier.App\ViewModels\**\*.cs"
             Exclude="..\..\src\BlackScreenIdentifier.App\ViewModels\bin\**\*;..\..\src\BlackScreenIdentifier.App\ViewModels\obj\**\*"
             LinkBase="Linked\App\ViewModels" />
