    <Compile Include="..\..\src\BlackScreenIdentifier.Rules\**\*.cs"
             Exclude="..\..\src\BlackScreenIdentifier.Rules\bin\**\*;..\..\src\BlackScreenIdentifier.Rules\obj\**\*"
             LinkBase="Linked\Rules" />
    <Compile Include="..\..\src\BlackScreenIdentifier.Actions\**\*.cs"
